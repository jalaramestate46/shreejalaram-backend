NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
SITE_URL=https://jalaramestate.com
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Use the Supabase Postgres connection string here, not the project https URL.
# Example: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=
# Optional aliases also supported by the backend:
# DATABASE_URL=
# POSTGRES_URL=
